# MongoDB Configuration
MONGO_URI=mongodb+srv://user:password@cluster0.mongodb.net/?appName=Cluster0
MONGO_DB=main
MONGO_COLLECTION=users

# Cloudflare Configuration (optional – only needed for DNS record creation)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_PROJECT_NAME=none
# Zone ID for DNS record creation (find in your Cloudflare dashboard, Overview page of the domain)
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
# Root domain used when creating DNS CNAME records (e.g. sycord.com -> <project>.sycord.com)
CLOUDFLARE_DOMAIN=sycord.com

# Server Configuration
SERVER_HOST=micro1.sycord.com
PORT=5000
DEBUG=False

