# Ignore git files
.git/
.gitignore

# Ignore build artifacts and dependencies
__pycache__/
*.pyc
*.pyo
venv/
.venv/
node_modules/
dist/
build/
.env
.env.local
.env.*

# Ignore system files
.DS_Store
Thumbs.db

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore temporary files
coverage/
.coverage
htmlcov/
.pytest_cache/
